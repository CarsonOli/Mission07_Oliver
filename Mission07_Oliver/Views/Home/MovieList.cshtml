@{
}

@model List<Movie>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Movie Collection</h4>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Year</th>
                            <th>Director</th>
                            <th>Category</th>
                            <th>Rating</th>
                            <th>Edited</th>
                            <th>Copied to Plex</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var movie in Model)
                        {
                            <tr>
                                <td>@movie.Title</td>
                                <td>@movie.Year</td>
                                <td>@movie.Director</td>
                                <td>@(movie.Category?.CategoryName ?? "—")</td>
                                <td>@movie.Rating</td>
                                <td>@(movie.Edited ? "Yes" : "No")</td>
                                <td>@(movie.CopiedToPlex ? "Yes" : "No")</td>
                                <td>
                                    <a class="btn btn-sm btn-warning me-1"
                                       asp-action="Edit"
                                       asp-route-id="@movie.MovieId">Edit</a>

                                    <a class="btn btn-sm btn-danger"
                                       asp-action="Delete"
                                       asp-route-id="@movie.MovieId">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>