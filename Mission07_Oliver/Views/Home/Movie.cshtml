@{
}
@model Movie

<h1>Submit a Movie</h1>

<form method="post">
    <input type="hidden" asp-for="MovieId" />

    <label asp-for="Title">Title: </label>
    <input type="text" asp-for="Title" />
    <br />
    <label asp-for="Director">Director: </label>
    <input type="text" asp-for="Director" />
    <br />
    <label asp-for="Year">Year: </label>
    <input type="number" asp-for="Year" />
    <br />
    <select asp-for="CategoryId">
        <option value="">Select a Category</option>
        @foreach (Category c in ViewBag.Categories)
        {
            <option value="@c.CategoryId">@c.CategoryName</option>
        }
    </select>
    <br />
    <label asp-for="Rating">Rating: </label>
    <input type="text" asp-for="Rating" />
    <br />
    <label asp-for="Edited">Edited: </label>
    <input type="checkbox" asp-for="Edited" />
    <br />
    <label asp-for="LentTo">Lent To: </label>
    <input type="text" asp-for="LentTo" />
    <br />
    <label asp-for="CopiedToPlex">Copied To Plex: </label>
    <input type="checkbox" asp-for="CopiedToPlex" />
    <br />
    <label asp-for="Notes">Notes: </label>
    <input type="text" asp-for="Notes" />
    <br />
    <button type="submit">Submit Movie</button>

    <div asp-validation-summary="All"></div>
</form>
